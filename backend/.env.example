# Server
PORT=3000

# SQLite cache file (relative to backend/ working dir)
DB_PATH=./data/cache.sqlite

# Supabase project JWT secret (Settings → API → JWT Secret).
# Used to verify access tokens locally. NEVER commit the real value.
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# OCT token address on Ethereum (DexScreener tokens lookup)
OCT_TOKEN_ADDRESS=0x4647e1fe715c9e23959022c2416c71867f5a6e80
# Price refresh interval in ms (default 5 min)
PRICE_INTERVAL_MS=300000
# Optional: pin Supabase token issuer, e.g. https://<ref>.supabase.co/auth/v1
# SUPABASE_JWT_ISSUER=
